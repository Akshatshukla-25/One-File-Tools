<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{displayName}} — Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cause&family=Coiny&display=swap" rel="stylesheet" />
    <style>
      /* === Reset === */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      /* === Base === */
      body {
        font-family: "Cause", cursive;
        font-size: 16px;
        line-height: 1.6;
        /* Pastel striped background */
        background: repeating-linear-gradient(90deg, #ffd1dc, #ffd1dc 50px, #e6e6fa 50px, #e6e6fa 100px, #d4edda 100px, #d4edda 150px);
        padding: 2rem;
      }

      a {
        color: #9b59b6;
        text-decoration: none;
        font-weight: bold;
      }
      a:hover {
        text-decoration: underline;
      }

      .source-code-link {
        color: rgb(125, 125, 255);
      }

      .container {
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem;
        /* Light yellow bg, border-radius, purple text */
        background-color: #ffffe0;
        border-radius: 15px;
        color: #8a2be2;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
      }

      /* Your styles here */
      header {
        text-align: center;
        margin-bottom: 2rem;
      }
      header img {
        /* Reverted to default display to rely on parent's text-align. */
        width: 150px;
        height: 150px;
        border-radius: 50%;
        border: 5px solid #e6e6fa;
        margin-bottom: 1rem;
      }
      h1 {
        font-family: "Coiny", cursive;
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
      }
      h2 {
        font-family: "Coiny", cursive;
        font-size: 2rem;
        border-bottom: 2px solid #418c53;
        padding-bottom: 0.5rem;
        margin-bottom: 1.5rem;
        margin-top: 2rem;
      }
      h3 {
        font-family: "Coiny", cursive;
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
      }
      section {
        margin-bottom: 2rem;
      }
      .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
      }
      .project-card {
        background: #fff;
        padding: 1.5rem;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: transform 0.2s ease-in-out;
      }
      .project-card:hover {
        transform: scale(1.02);
      }
      .project-card .tech-stack span {
        color: #8a2be2;
        padding: 0.25rem 0.5rem;
        border-radius: 5px;
        font-size: 0.8rem;
        margin-right: 0.5rem;
        display: inline-block;
        margin-top: 0.5rem;
      }
      .project-card .tech-stack span:nth-child(4n + 1) {
        background: #e6e6fa; /* Pastel Purple */
      }
      .project-card .tech-stack span:nth-child(4n + 2) {
        background: #d4edda; /* Pastel Green */
      }
      .project-card .tech-stack span:nth-child(4n + 3) {
        background: #d1e7ff; /* Pastel Blue */
      }
      .project-card .tech-stack span:nth-child(4n + 4) {
        background: #ffd1dc; /* Pastel Pink */
      }
      .card-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .info-card {
        background: #ffd1dc; /* Pastel Pink */
        padding: 1.5rem;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: transform 0.2s ease-in-out;
      }
      .info-card:hover {
        transform: scale(1.02);
      }
      .language-card {
        background: #d4edda; /* Pastel Green */
      }
      .languages-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
      }
      .language-card .proficiency {
        text-transform: capitalize;
      }
      footer {
        text-align: center;
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid #e6e6fa;
        opacity: 0.8;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <!-- Hero -->
      <header>
        <img class="hero-photo" src="https://i.sstatic.net/2fRi5z4Ml.png" alt="Jane Doe">
        <h1>{{displayName}}</h1>
        {{#title}}<p style="font-size: 1.2rem; opacity: 0.9;">{{title}}</p>{{/title}}
        {{#bio}}<p style="margin-top: 1rem;">{{bio}}</p>{{/bio}}
        <nav style="margin-top: 1.5rem; display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;">
          {{#email}}<a href="mailto:{{email}}">Email</a>{{/email}}
          {{#website}}<a href="{{website}}">{{stripProtocol website}}</a>{{/website}}
          {{#socialLinks}}<a href="{{url}}">{{label}}</a>{{/socialLinks}}
        </nav>
      </header>

      <!-- Projects -->
      {{#has projects}}
        <section>
          <h2>Projects</h2>
          <div class="projects-grid">
            {{#projects}}
              <article class="project-card">
                <h3>{{name}}</h3>
                {{#tagline}}<p style="opacity: 0.8; font-style: italic;">{{tagline}}</p>{{/tagline}}
                {{#description}}<p style="margin-top: 0.5rem;">{{description}}</p>{{/description}}
                {{#has techStack}}
                  <div class="tech-stack" style="margin-top: 1rem;">
                    {{#techStack}}<span>{{.}}</span>{{/techStack}}
                  </div>
                {{/has}}
                <div style="margin-top: 1rem;">
                  {{#liveUrl}}<a href="{{liveUrl}}">Live Demo</a>{{/liveUrl}}
                  {{#repoUrl}} | <a href="{{repoUrl}}" class="source-code-link">Source Code</a>{{/repoUrl}}
                </div>
              </article>
            {{/projects}}
          </div>
        </section>
      {{/has}}

      <!-- Skills -->
      {{#has skills}}
        <section>
          <h2>Skills</h2>
          {{#skills}}
            <div style="margin-bottom: 1rem;">
              <h3>{{category}}</h3>
              <p>
                {{#items}}{{name}}{{^@last}}, {{/@last}}{{/items}}
              </p>
            </div>
          {{/skills}}
        </section>
      {{/has}}

      <!-- Experience -->
      {{#has experience}}
        <section>
          <h2>Experience</h2>
          <div class="card-list">
            {{#experience}}
              <article class="info-card">
                <h3>{{role}} at {{company}}</h3>
                <p style="opacity: 0.8; font-style: italic;">{{fmtDate startDate}} – {{fmtDate endDate}}</p>
                {{#description}}<p style="margin-top: 0.5rem;">{{description}}</p>{{/description}}
                {{#has highlights}}
                  <ul style="margin-top: 1rem; padding-left: 1.5rem;">
                    {{#highlights}}<li>{{.}}</li>{{/highlights}}
                  </ul>
                {{/has}}
              </article>
            {{/experience}}
          </div>
        </section>
      {{/has}}

      <!-- Education -->
      {{#has education}}
        <section>
          <h2>Education</h2>
          <div class="card-list">
            {{#education}}
              <article class="info-card">
                <h3>{{degree}}{{#if field}} in {{field}}{{/if}}</h3>
                <p>{{institution}}</p>
                <p style="opacity: 0.8; font-style: italic;">{{fmtDate startDate}} – {{fmtDate endDate}}</p>
              </article>
            {{/education}}
          </div>
        </section>
      {{/has}}

      <!-- Languages -->
      {{#has languages}}
        <section>
          <h2>Languages</h2>
          <div class="languages-grid">
            {{#languages}}<div class="info-card language-card"><strong>{{language}}</strong> - <span class="proficiency">{{proficiency}}</span></div>{{/languages}}
          </div>
        </section>
      {{/has}}
    </div>

    <footer>
      <p>Built with <a href="{{toolsUrl}}">One File Tools</a></p>
    </footer>
  </body>
</html>